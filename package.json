{
  "name": "@encryptedclipboard/crypto",
  "version": "1.1.1",
  "author": "Encrypted Clipboard Manager <oss@encryptedclipboard.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/encryptedclipboard/crypto.git"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.10",
    "typescript": "^5.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "description": "Unified E2E encryption logic library",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/encryptedclipboard/crypto",
  "keywords": [
    "encryption",
    "decryption",
    "crypto",
    "e2e",
    "end-to-end-encryption",
    "aes-gcm",
    "pbkdf2",
    "web-crypto",
    "security",
    "encrypted-clipboard-manager"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:cjs": "tsc",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build": "rm -rf dist && bun run build:cjs && bun run build:esm",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "types": "./dist/cjs/index.d.ts"
}
